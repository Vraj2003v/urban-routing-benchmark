postgres_data/
neo4j_data/
neo4j_logs/

# ─── IDE / Editor ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ─── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

